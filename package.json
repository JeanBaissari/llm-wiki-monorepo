{
  "name": "llm-wiki-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Knowledge base operating system — AI agents compile raw sources into persistent, cross-linked Markdown wikis",
  "keywords": [
    "wiki",
    "knowledge-base",
    "llm",
    "ai-agents",
    "mcp",
    "knowledge-graph",
    "markdown",
    "research-tool",
    "second-brain",
    "claude",
    "hermes"
  ],
  "workspaces": [
    "mcp-server",
    "graph-engine",
    "web-viewer",
    "audit-shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "install:all": "bash install.sh",
    "mcp": "node mcp-server/dist/index.js",
    "graph": "node graph-engine/dist/index.js",
    "web": "cd web-viewer && npm start",
    "lint:wiki": "python3 skill/scripts/lint_wiki.py",
    "scaffold": "python3 skill/scripts/scaffold.py",
    "ingest": "python3 skill/scripts/ingest.py",
    "deep-research": "python3 skill/scripts/deep_research.py",
    "insights": "python3 skill/scripts/graph_insights.py",
    "link-suggest": "python3 skill/scripts/link_suggest.py",
    "backup": "python3 skill/scripts/backup.py",
    "benchmark": "python3 skill/scripts/benchmark.py"
  },
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.10"
  }
}
